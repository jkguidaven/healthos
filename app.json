{
  "expo": {
    "name": "HealthOS",
    "slug": "healthos",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.healthos.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.healthos.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "healthos",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-sqlite",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#1D9E75",
          "imageWidth": 260
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "06cbe8d2-c803-44c1-87c3-ba8bf83a6f93"
      }
    },
    "owner": "jkguidaven"
  }
}
